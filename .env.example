# =============================================================
#  AI Canvas Generator — 環境變數範本
#  複製此檔案為 .env 並填入你的金鑰
#  cp .env.example .env
# =============================================================

# Hugging Face API Token
# 取得方式：https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# (可選) 預設使用的模型
HF_DEFAULT_MODEL=black-forest-labs/FLUX.1-schnell

# (可選) 預設圖像尺寸
HF_DEFAULT_WIDTH=512
HF_DEFAULT_HEIGHT=512
